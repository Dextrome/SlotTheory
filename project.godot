; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Slot Theory"
config/version="0.1.8"
config/quit_on_go_back=false
boot_splash/show_image=false 
run/main_scene="res://Scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon2.png"

[autoload]

LeaderboardManager="*res://Scripts/Core/LeaderboardManager.cs"
AchievementManager="*res://Scripts/Core/AchievementManager.cs"
AchievementToast="*res://Scripts/UI/AchievementToast.cs"
SettingsManager="*res://Scripts/Core/SettingsManager.cs"
SoundManager="*res://Scripts/Core/SoundManager.cs"
Transition="*res://Scripts/Core/Transition.cs"
HighScoreManager="*res://Scripts/Core/HighScoreManager.cs"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="SlotTheory"

[rendering]

textures/vram_compression/import_etc2_astc=true
viewport/hdr_2d=true

[settings]

Export/Android/experimental_csharp_android_export=true
